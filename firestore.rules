rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /contracts/{contractId} {
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /clauses/{clauseId} {
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /riskAnalysis/{analysisId} {
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /clauseRisk/{riskId} {
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /summaries/{summaryId} {
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /reports/{reportId} {
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /complianceAnalysis/{analysisId} {
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /negotiationSuggestions/{suggestionId} {
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /contractReadiness/{readinessId} {
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /contractChunks/{chunkId} {
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /chatSessions/{sessionId} {
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /chatMessages/{messageId} {
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /evaluationResults/{resultId} {
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /evaluationReports/{reportId} {
      allow read, write: if request.auth != null;
    }
    match /humanEvaluations/{evaluationId} {
      allow read, write: if request.auth != null;
    }
  }
}
